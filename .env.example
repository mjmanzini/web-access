# Database (matches docker-compose.yml defaults)
POSTGRES_DB=webaccess
POSTGRES_USER=webaccess
POSTGRES_PASSWORD=webaccess

# Node connection string (used by the signaling server)
DATABASE_URL=postgres://webaccess:webaccess@localhost:5432/webaccess

# Set to anything truthy to terminate TLS in Node directly (selfsigned)
HTTPS=

# Optional TURN servers. When unset, only STUN is used.
TURN_URL=
TURN_USERNAME=
TURN_CREDENTIAL=
