PORT=4000
CORS_ORIGIN=*
# Optional: set a shared secret so only your Host/Client can use this server
SIGNALING_SHARED_SECRET=

# --- ICE / TURN configuration ----------------------------------------------
# Comma-separated STUN URLs (defaults to Google's public STUN).
STUN_URLS=stun:stun.l.google.com:19302

# Comma-separated TURN URLs, e.g.:
#   TURN_URL=turn:turn.example.com:3478,turns:turn.example.com:5349
TURN_URL=

# Option A: static TURN credentials (simple, but creds live forever).
TURN_USERNAME=
TURN_PASSWORD=

# Option B: time-limited REST credentials. Must match coturn's
#   static-auth-secret / use-auth-secret=true.  Recommended in production.
TURN_SHARED_SECRET=
TURN_TTL_SECONDS=86400

# --- Storage backend --------------------------------------------------------
# Defaults to postgres. Set to firebase to enable the Firebase adapter.
STORAGE_BACKEND=postgres

# Firebase Admin SDK credentials for STORAGE_BACKEND=firebase.
# Either set GOOGLE_APPLICATION_CREDENTIALS to a service-account JSON path,
# or provide the inline variables below.
GOOGLE_APPLICATION_CREDENTIALS=
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_STORAGE_BUCKET=
FIREBASE_DATABASE_URL=
