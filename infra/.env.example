# Public IPv4 of the VPS (required so coturn advertises the right address).
PUBLIC_IP=203.0.113.10

# Public IP or hostname mediasoup advertises in ICE candidates.
# Usually the same as PUBLIC_IP on a single-host deployment.
MEDIASOUP_ANNOUNCED_IP=203.0.113.10

# Public HTTPS hostname for the browser app.
WEB_HOSTNAME=example.com

# WebAuthn passkeys are bound to the browser app origin / RP ID.
# In compose we derive:
#   WEBAUTHN_ORIGIN=https://${WEB_HOSTNAME}
#   WEBAUTHN_RP_ID=${WEB_HOSTNAME}

# Public HTTPS hostname for the signaling service.
SIGNALING_HOSTNAME=signal.example.com

# Your TURN realm, normally a DNS name you control.
TURN_REALM=turn.example.com

# Long random string, shared with signaling-server for time-limited credentials.
TURN_SHARED_SECRET=change-me-to-a-long-random-string

# UDP port range coturn allocates for media relay. Must be open in the firewall.
TURN_MIN_PORT=49160
TURN_MAX_PORT=49200

# Mediasoup media port range exposed by the signaling server. Must also be open.
MEDIASOUP_MIN_PORT=40000
MEDIASOUP_MAX_PORT=40200

# Where the web-client expects to reach the signaling service.
SIGNALING_PUBLIC_URL=https://signal.example.com

# --- Database (Postgres in compose stack) ---
POSTGRES_DB=webaccess
POSTGRES_USER=webaccess
# REQUIRED. Generate with: openssl rand -hex 32
POSTGRES_PASSWORD=change-me-to-a-long-random-string

# --- Social login (OAuth) ---
# Each provider is optional — only those with both client id + secret get
# rendered as a button on the onboarding page. Authorized redirect URI for
# every provider is:  https://${SIGNALING_HOSTNAME}/api/auth/oauth/<provider>/callback
#
# Google Cloud Console -> OAuth 2.0 Client (Web application).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# GitHub Developer Settings -> OAuth Apps.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Long random string used to sign the OAuth state cookie. Generate with:
#   openssl rand -hex 32
OAUTH_STATE_SECRET=change-me-to-a-long-random-string
